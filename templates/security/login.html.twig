{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}
<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="{{ path('app_cours') }}">Cours</a>
    <a href="{{ path('app_chien_dashboard') }}">Dashboard</a>
    <a href="{{ path('app_register') }}" class="nav-cta">S'inscrire</a>
    <a href="{{ path('app_login') }}" class="nav-cta">Connexion</a>
  </div>
</nav>

<div class="admin-container">
    <div class="admin-header">
        <h1>Connexion</h1>
        <a href="{{ path('app_register') }}" class="btn btn-ghost btn-sm">Créer un compte →</a>
    </div>

    <div class="form-symfony">

        <form method="post" action="{{ path('app_login') }}">        
        {% if error %}
            <div style="background:#fdf0f0;color:#e05c5c;border:1px solid #f0c0c0;border-radius:8px;padding:0.85rem 1rem;margin-bottom:1rem;font-size:0.85rem;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div style="font-size:0.85rem;color:var(--ink-3);margin-bottom:1rem;">
                Connecté en tant que {{ app.user.userIdentifier }} —
                <a href="{{ logout_path() }}" style="color:var(--forest)">Se déconnecter</a>
            </div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="username">Email</label>
                <input type="email" value="{{ last_username }}" name="_username" id="username" autocomplete="email" required autofocus>
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" name="_password" id="password" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <button class="btn" type="submit">Se connecter</button>
        </form>

        <p class="form-link">Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a></p>
    </div>
</div>

<footer>
    <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>

{% endblock %}