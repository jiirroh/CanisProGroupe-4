<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
    </head>
    <body>
    <nav>
        <a href="{{ path('app_home') }}" class="nav-logo">
            <img src="{{ asset('images/logo-canispro.png') }}" width="170px" alt="CanisPro Logo">
        </a>
        <div class="nav-right">
            <div class="nav-links">
                {% if app.user %}
                    <div class="nav-user">
                        <div class="nav-avatar">{{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}</div>
                        {{ app.user.prenom }} {{ app.user.nom }}
                    </div>
                    <a href="{{ path('app_chien_dashboard') }}">Espace propriétaire</a>
                    <a href="{{ path('app_logout') }}">Déconnexion</a>
                {% else %}
                    <a href="{{ path('app_login') }}">Connexion</a>
                    <a href="{{ path('app_register') }}" class="nav-cta">S'inscrire</a> 
                {% endif %}
            </div>
        </div>
    </nav>
    <div class="page-nav">
        <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">Accueil</a>
        <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_cours' ? 'active' : '' }}" href="{{ path('app_cours') }}">Cours</a>
        {% if is_granted('ROLE_USER') %}
            <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_chien_dashboard' ? 'active' : '' }}" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
        {% endif %}
        {% if is_granted('ROLE_ADMIN') %}
            <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_cours_index' ? 'active' : '' }}" href="{{ path('app_cours_index') }}">Gérer les cours</a>
            <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_chien_liste' ? 'active' : '' }}" href="{{path('app_chien_liste')}}">Gérer les chiens</a>
            <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_inscription_index' ? 'active' : '' }}" href="{{ path('app_inscription_index') }}">Gérer les réservations</a>
            <a class="page-nav-link {{ app.request.attributes.get('_route') == 'app_proprietaire_index' ? 'active' : '' }}" href="{{ path('app_proprietaire_index') }}">Gérer les propriétaires</a>
        {% endif %}
    </div>
        {% block body %}{% endblock %}
    </body>
</html>
