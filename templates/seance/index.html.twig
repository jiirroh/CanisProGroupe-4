{% extends 'base.html.twig' %}

{% block title %}Liste des séances{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}
<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="{{ path('app_cours') }}">Cours</a>
    <a href="{{ path('app_chien_dashboard') }}">Dashboard</a>
    <a href="#" class="nav-cta">S'inscrire</a>
    <a href="#" class="nav-cta">Connexion</a>
  </div>
</nav>

<div class="page-nav">
  <a class="page-nav-link" href="{{ path('app_home') }}">Accueil</a>
  <a class="page-nav-link" href="{{ path('app_cours') }}">Cours</a>
  <a class="page-nav-link" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
  <a class="page-nav-link" href="{{ path('app_chien_liste') }}">Liste des chiens</a>
  <a class="page-nav-link" href="{{ path('app_proprietaire_index') }}">Liste des propriétaires</a>
  <a class="page-nav-link active" href="{{ path('app_seance_index') }}">Liste des séances</a>
</div>

<div class="admin-container">
    <div class="admin-header">
        <h1>Gestion des séances</h1>
        <a href="{{ path('app_seance_new') }}" class="btn-add">+ Ajouter une séance</a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Date & Heure</th>
                    <th>Nb max chiens</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for seance in seances %}
                    <tr>
                        <td class="td-nom">{{ seance.id }}</td>
                        <td>{{ seance.dateHeure ? seance.dateHeure|date('d/m/Y H:i') : '—' }}</td>
                        <td>{{ seance.nbMaxChien }}</td>
                        <td class="td-actions">
                            <a href="{{ path('app_seance_show', {'id': seance.id}) }}" class="btn btn-outline btn-sm">Voir</a>
                            <a href="{{ path('app_seance_edit', {'id': seance.id}) }}" class="btn btn-ghost btn-sm">Modifier</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="td-empty">Aucune séance enregistrée.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<footer>
    <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>

{% endblock %}