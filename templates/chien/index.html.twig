{# {% extends 'base.html.twig' %}

{% block title %}CanisPro — École de dressage canin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}

<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="#cours">Cours</a>
    <a href="{{ path('app_chien_dashboard') }}">Dashboard</a>
    <a href="{{ path('app_register') }}" class="nav-cta">S'inscrire</a>
    <a href="{{ path('app_login') }}" class="nav-cta">Connexion</a>
  </div>
</nav>

<div class="page-nav">
  <a class="page-nav-link" href="{{ path('app_home') }}">Accueil</a>
  <a class="page-nav-link" href="{{ path('app_cours_index') }}">Cours</a>
  <a class="page-nav-link" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
  <a class="page-nav-link" href="{{path('app_chien_liste')}}">Liste des chiens</a>
</div>

<!-- ──────────────────────────────────────
     PAGE 1 — HERO / LANDING
─────────────────────────────────────── -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow">École de dressage canin</p>
      <h1>Des cours adaptés à chaque <em>compagnon</em></h1>
      <p>Trouvez le cours parfait pour votre chien, réservez en ligne et suivez sa progression avec vos éducateurs certifiés.</p>
      <div class="hero-actions">
        <a class="page-nav-link" href="{{ path('app_cours_index') }}">Voir les cours →</a>
        <a href="#dashboard" class="btn-ghost-hero">Espace propriétaire</a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="stat-num">248</div>
          <div class="stat-label">Chiens formés</div>
        </div>
        
        <div>
          <div class="stat-num">96%</div>
          <div class="stat-label">Satisfaction</div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card">
        <div class="hero-card-icon">🎓</div>
        <h4>Obéissance de base</h4>
        <p>Assis, couché, rappel — les fondamentaux pour un chien épanoui</p>
      </div>
      <div class="hero-card">
        <div class="hero-card-icon">🏃</div>
        <h4>Agility</h4>
        <p>Parcours fun et sportifs</p>
      </div>
      <div class="hero-card">
        <div class="hero-card-icon">🐾</div>
        <h4>Socialisation</h4>
        <p>Interactions avec autres chiens</p>
      </div>
    </div>
  </div>
</section>

<!-- ──────────────────────────────────────
     PAGE 2 — LISTE DES COURS
─────────────────────────────────────── -->
<section>
  <div class="section-inner">
    <p class="section-label">Nos formations</p>
    <h2 class="section-title">Tous les <em>cours disponibles</em></h2>
    <p class="section-sub">Des séances adaptées à tous les niveaux, en groupe ou en individuel.</p>

    <div class="cours-grid">
      {% for cour in cours %}
        <div class="cours-card">
          <div class="cours-img {{ loop.index is odd ? 'green' : (loop.index % 3 == 2 ? 'amber' : 'blue') }}">
            {{ loop.index == 1 ? '🐕' : (loop.index == 2 ? '🏆' : '🤝') }}
            {% if loop.index == 1 %}
              <span class="cours-badge new">Nouveau</span>
            {% endif %}
          </div>
          <div class="cours-body">
            <span class="cours-level">{{ cour.niveau }}</span>
            <h3 class="cours-title">{{ cour.libelle }}</h3>
            <p class="cours-desc">{{ cour.descriptions|slice(0, 100) }}...</p>
            <div class="cours-meta">
              <span>📅 {{ cour.dateHeure ? cour.dateHeure|date('D H:i') : '—' }}</span>
              <span>👥 {{ cour.nbChien }} places</span>
            </div>
            <div class="cours-footer">
              <div class="cours-price">{{ cour.prix }}€ <small>/ séance</small></div>
              <a href="{{ path('app_inscription_index') }}" class="btn-reserver">Réserver</a>
            </div>
          </div>
        </div>
      {% else %}
        <p style="color: var(--ink-3); grid-column: 1/-1; text-align:center; padding: 3rem 0;">Aucun cours disponible pour le moment.</p>
      {% endfor %}
    </div>
  </div>
</section>


<footer>
  <strong>CanisPro</strong> — Maquette Symfony · Projet école · 2026
</footer>


{% endblock %}
 #}