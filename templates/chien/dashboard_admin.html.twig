{% extends 'base.html.twig' %}

{% block title %}Dashboard Admin{% endblock %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}



<!-- ══════════════════════════════════════
     PAGE 1 — MON ESPACE PROPRIÉTAIRE
══════════════════════════════════════ -->
<section class="espace-section" id="espace">
  <div class="section-inner">
    <p class="section-label">{{ isAdmin ? 'Espace administrateur' : 'Espace propriétaire' }}</p>
    <h2 class="section-title">Mon <em>espace</em> {{ isAdmin ? 'admin' : 'propriétaire' }}</h2>

    <div class="espace-grid">

  <!-- Contenu principal -->
  <div class="dash-main">

    <!-- Bienvenue -->
    <div class="dash-welcome">
      <div>
        <h2>Bonjour {{ app.user ? app.user.prenom : 'Visiteur' }}</h2>
        <p>{{ isAdmin ? 'Vous êtes en mode administrateur.' : 'Gérez vos chiens et vos inscriptions.' }}</p>
      <a href="#catalogue" class="btn btn-amber">Réserver un cours</a>
    </div>

    <!-- Mes chiens -->
    <div>
      <div class="sub-header">
        <h3>Les chiens</h3>
        <a href="#" class="btn btn-ghost btn-sm">+ Ajouter un chien</a>
      </div>
      <div class="chiens-row">

        {% for chien in chiens %}
        <div class="chien-card">
          <div class="chien-card-top">
            <div class="chien-icon green">🐕</div>
            <div>
              <div class="chien-name">{{ chien.nom }}</div>
              <div class="chien-breed">{{ chien.race }} · {{ chien.age }}</div>
            </div>
          </div>
          <div class="chien-stats">
            <div class="chien-stat">
              <div class="chien-stat-val">{{ chien.inscriptions|length }}</div>
              <div class="chien-stat-label">Cours</div>
            </div>
            <div class="chien-stat">
              <div class="chien-stat-val">80%</div>
              <div class="chien-stat-label">Progrès</div>
            </div>
            <div class="chien-stat">
              {% set upcoming_courses = 0 %}
              {% for inscription in chien.inscriptions %}
                  {% if inscription.cours.dateHeure > "now" %}
                      {% set upcoming_courses = upcoming_courses + 1 %}
                  {% endif %}
              {% endfor %}
              <div class="chien-stat-val">{{ upcoming_courses }}</div>
              <div class="chien-stat-label">À venir</div>
            </div>
          </div>
          <div class="chien-card-footer">
            <a href="#fiche" class="btn btn-outline btn-sm">Voir fiche</a>
            <a href="{{ path('app_inscription_new', {'chien': chien.id}) }}" class="btn btn-primary btn-sm">Inscrire</a>
          </div>
        </div>
        {% else %}
            <p>Aucun chien à afficher pour le moment.</p>
        {% endfor %}

        <!-- Ajouter -->
        <div class="chien-card chien-card-add">
          <div class="admin-container">
            <div class="admin-header">
              <h1>Ajouter un chien</h1>
              <a href="{{ path('app_chien_liste') }}" class="btn btn-ghost btn-sm">← Retour</a>
            </div>
            {{ include('chien/_form.html.twig', {'form': form, 'button_label': 'Ajouter'}) }}
          </div>
        </div>
      </div> {# .chiens-row #}
    </div> {# contenu principal section #}
  </div> {# .dash-main #}
</div> {# .espace-grid #}
  </div> {# .section-inner #}
</section>

<footer>
  <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>

{% endblock %}

    
