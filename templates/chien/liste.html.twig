{% extends 'base.html.twig' %}

{% block title %}Administration Chiens{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}
<header>
</header>

<div class="admin-container">
    <div class="admin-header">
        <h1>Gestion des chiens</h1>
        <a href="{{ path('chien_ajouter') }}" class="btn-add">
            + Ajouter un chien
        </a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Race</th>
                    <th>Age</th>
                    <th>Proprietaire</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for chien in chiens %}
                    <tr>
                        <td class="td-nom">{{ chien.nom }}</td>
                        <td class="td-race">{{ chien.race }}</td>
                        <td class="age-text">{{ chien.age }} ans</td>
                        <td class="td-proprietaire">{{ chien.proprietaire ? chien.proprietaire.nom : 'Aucun' }}</td>
                        <td class="td-actions">
                            <a href="{{ path('chien_modification', {'id': chien.id}) }}" class="btn" style="background: var(--forest-3); color: white; padding: 0.5rem 1rem; font-size: 0.8rem;">
                                Modifier
                            </a>
                            <form method="POST" action="{{ path('app_chien_delete', {'id': chien.id}) }}" onsubmit="return confirm('Supprimer ce chien ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ chien.id) }}">
                                <button type="submit" class="btn-delete">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="text-align: center; padding: 3rem; color: var(--ink-3);">Aucun chien enregistré.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<footer>
    <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>
{% endblock %}