{% extends 'base.html.twig' %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block title %}Administration Chien{% endblock %}

{% block body %}
<div class="admin-container">
    <div class="admin-header">
        <h1>Gestion</h1>
        <a href="{{ path('app_chien_liste') }}" class="btn-add">
            + Ajouter un produit
        </a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Race</th>
                    <th>Age</th>
                    <th>Propriétaire</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for chien in chiens %}
                    <tr>
                        <td class="td-nom">{{ chien.nom }}</td>
                        <td class="td-race">{{ chien.race|slice(0, 60) }}...</td>
                        <td class="age-text">{{ chien.age }} ans</td>
                        <td class="td-proprietaire"></td>
                        <td class="td-actions"></td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}