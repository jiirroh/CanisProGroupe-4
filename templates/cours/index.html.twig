{% extends 'base.html.twig' %}
{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}
{% block title %}Cours{% endblock %}

{% block body %}
<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="#cours">Cours</a>
    <a href="{{ path('app_chien_dashboard') }}">Dashboard</a>
    <a href="#profil" class="nav-cta">S'inscrire</a>
    <a href="#" class="nav-cta">Connexion</a>
  </div>
</nav>
    <h1>Cours </h1>
   <a href="{{ path('app_cours_new') }}" class="btn-add">
            Nouveau cours
        </a>

    <table class="table">
        <thead>
            <tr>
                <th>Nom des cours</th>
                <th>Niveau</th>
                <th>Descriptions</th>
                <th>Prix</th>
                <th>Date et l'heure</th>
                <th>Nombre de chiens</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for cour in cours %}
            <tr>
                <td>{{ cour.libelle }}</td>
                <td>{{ cour.niveau }}</td>
                <td>{{ cour.descriptions }}</td>
                <td>{{ cour.prix }}</td>
                <td>{{ cour.dateHeure ? cour.dateHeure|date('Y-m-d à H:i:s') : '' }}</td>
                <td>{{ cour.nbChien }}</td>
                <td class="td-actions">
                            <a href="{{ path('chien_modification', {'id': cour.id}) }}" class="btn" style="background: var(--forest-3); color: white; padding: 0.5rem 1rem; font-size: 0.8rem;">
                                Modifier
                            </a>
                            <form method="POST" action="{{ path('app_chien_delete', {'id': cour.id}) }}" onsubmit="return confirm('Supprimer ce chien ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cour.id) }}">
                                <button type="submit" class="btn-delete">Supprimer</button>
                            </form>
                        </td>
                    </tr>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

   
{% endblock %}
