{% extends 'base.html.twig' %}

{% block title %}Cours{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}
<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="{{ path('app_cours') }}">Cours</a>
    <a href="{{ path('app_chien_dashboard') }}">Dashboard</a>
    <a href="#" class="nav-cta">S'inscrire</a>
    <a href="#" class="nav-cta">Connexion</a>
  </div>
</nav>

<div class="page-nav">
  <a class="page-nav-link" href="{{ path('app_home') }}">Accueil</a>
  <a class="page-nav-link active" href="{{ path('app_cours') }}">Cours</a>
  <a class="page-nav-link" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
  <a class="page-nav-link" href="{{ path('app_chien_liste') }}">Gérer les chiens</a>
  <a class="page-nav-link" href="{{ path('app_proprietaire_index') }}">Gérer les propriétaires</a>
   <a class="page-nav-link" href="{{ path('app_cours_index') }}">Gérer les cours</a> 
</div>

<div class="admin-container">
    <div class="admin-header">
        <h1>Gestion des cours</h1>
        <a href="{{ path('app_cours_new') }}" class="btn-add">+ Nouveau cours</a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Niveau</th>
                    <th>Description</th>
                    <th>Prix</th>
                    <th>Date & Heure</th>
                    <th>Nb chiens</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for cour in cours %}
                    <tr>
                        <td class="td-nom">{{ cour.libelle }}</td>
                        <td>{{ cour.niveau }}</td>
                        <td class="td-race">{{ cour.descriptions|slice(0, 60) }}...</td>
                        <td>{{ cour.prix }} €</td>
                        <td>{{ cour.dateHeure ? cour.dateHeure|date('d/m/Y à H:i') : '—' }}</td>
                        <td>{{ cour.nbChien }}</td>
                        <td class="td-actions">
                            <a href="{{ path('app_cours_edit', {'id': cour.id}) }}" class="btn btn-outline btn-sm">Modifier</a>
                            <form method="POST" action="{{ path('app_cours_delete', {'id': cour.id}) }}" onsubmit="return confirm('Supprimer ce cours ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ cour.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="td-empty">Aucun cours enregistré.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<footer>
    <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>

{% endblock %}