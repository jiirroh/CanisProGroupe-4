{% extends 'base.html.twig' %}

{% block title %}Administration Propriétaires{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}
<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="{{ path('app_cours') }}">Cours</a>
    <a href="{{ path('app_chien_dashboard') }}">Dashboard</a>
    <a href="#" class="nav-cta">S'inscrire</a>
    <a href="#" class="nav-cta">Connexion</a>
  </div>
</nav>

<div class="page-nav">
  <a class="page-nav-link" href="{{ path('app_home') }}">Accueil</a>
  <a class="page-nav-link" href="{{ path('app_cours') }}">Cours</a>
  <a class="page-nav-link" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
  <a class="page-nav-link" href="{{ path('app_chien_liste') }}">Liste des chiens</a>
  <a class="page-nav-link active" href="{{ path('app_proprietaire_index') }}">Liste des propriétaires</a>
  <a class="page-nav-link" href="{{ path('app_seance_index') }}">Liste des séances</a>
</div>

<div class="admin-container">
    <div class="admin-header">
        <h1>Gestion des propriétaires</h1>
        <a href="{{ path('app_proprietaire_new') }}" class="btn-add">+ Ajouter un propriétaire</a>
    </div>

    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for proprietaire in proprietaires %}
                    <tr>
                        <td class="td-nom">{{ proprietaire.nom }}</td>
                        <td class="td-proprietaire">{{ proprietaire.prenom }}</td>
                        <td class="td-actions">
                            <a href="{{ path('app_proprietaire_edit', {'id': proprietaire.id}) }}" class="btn btn-outline btn-sm">Modifier</a>
                            <form method="POST" action="{{ path('app_proprietaire_delete', {'id': proprietaire.id}) }}" onsubmit="return confirm('Supprimer ?');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ proprietaire.id) }}">
                                <button type="submit" class="btn btn-danger btn-sm">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="td-empty">Aucun propriétaire enregistré.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<footer>
    <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>

{% endblock %}