{% extends 'base.html.twig' %}

{% block title %}Ajouter un propriétaire{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}
<nav>
<div class="nav-container">
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
 {% if app.user %}
    {# L'utilisateur est connecté, on affiche le bouton de déconnexion #}
    <a href="{{ path('app_logout') }}">Déconnexion</a>
{% else %}
    {# L'utilisateur n'est pas connecté, on affiche le bouton de connexion #}
    <a href="{{ path('app_login') }}">Connexion</a>
    
    {# Tu peux aussi ajouter le bouton d'inscription ici si tu en as un #}
    <a href="{{ path('app_register') }}">S'inscrire</a> 
{% endif %}
</div>
</nav>

<div class="page-nav">
  <a class="page-nav-link" href="{{ path('app_home') }}">Accueil</a>
  <a class="page-nav-link active" href="{{ path('app_cours') }}">Cours</a>
  <a class="page-nav-link" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
  <a class="page-nav-link" href="{{ path('app_chien_liste') }}">Gérer les chiens</a>
  <a class="page-nav-link" href="{{ path('app_proprietaire_index') }}">Gérer les propriétaires</a>
  <a class="page-nav-link" href="{{ path('app_cours_index') }}">Gérer les cours</a>
  <a class="page-nav-link" href="{{ path('app_inscription_index') }}">Gérer les Reservations</a>
</div>

<div class="admin-container">
    <div class="admin-header">
        <h1>Ajouter un propriétaire</h1>
        <a href="{{ path('app_proprietaire_index') }}" class="btn btn-ghost btn-sm">← Retour</a>
    </div>

    {{ include('proprietaire/_form.html.twig') }}
</div>

<footer>
    <strong>CanisPro</strong> — Maquette Symfony · Espace Propriétaire · 2026
</footer>

{% endblock %}