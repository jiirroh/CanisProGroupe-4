{% extends 'base.html.twig' %}

{% block title %}CanisPro — École de dressage canin{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
{% endblock %}

{% block body %}

<nav>
  <img src="{{ asset('images/logo-canispro.png') }}" width="170px">
  <div class="nav-links">
    <a href="#cours">Cours</a>
    <a href="#dashboard">Dashboard</a>
    <a href="#profil" class="nav-cta">S'inscrire</a>
    <a href="#" class="nav-cta">Connexion</a>
  </div>
</nav>

<div class="page-nav">
  <a class="page-nav-link active" href="#hero">Accueil</a>
  <a class="page-nav-link" href="#cours">Cours</a>
  <a class="page-nav-link" href="{{ path('app_chien_dashboard') }}">Dashboard</a>
</div>


<!-- ──────────────────────────────────────
     PAGE 1 — HERO / LANDING
─────────────────────────────────────── -->
<section class="hero" id="hero">
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow">École de dressage canin</p>
      <h1>Des cours adaptés à chaque <em>compagnon</em></h1>
      <p>Trouvez le cours parfait pour votre chien, réservez en ligne et suivez sa progression avec vos éducateurs certifiés.</p>
      <div class="hero-actions">
        <a href="#cours" class="btn-primary-hero">Voir les cours →</a>
        <a href="#dashboard" class="btn-ghost-hero">Espace propriétaire</a>
      </div>
      <div class="hero-stats">
        <div>
          <div class="stat-num">248</div>
          <div class="stat-label">Chiens formés</div>
        </div>
        
        <div>
          <div class="stat-num">96%</div>
          <div class="stat-label">Satisfaction</div>
        </div>
        <div>
          <div class="stat-num">35 ans</div>
          <div class="stat-label">Expérience</div>
        </div>
      </div>
    </div>
    <div class="hero-visual">
      <div class="hero-card">
        <div class="hero-card-icon">🎓</div>
        <h4>Obéissance de base</h4>
        <p>Assis, couché, rappel — les fondamentaux pour un chien épanoui</p>
      </div>
      <div class="hero-card">
        <div class="hero-card-icon">🏃</div>
        <h4>Agility</h4>
        <p>Parcours fun et sportifs</p>
      </div>
      <div class="hero-card">
        <div class="hero-card-icon">🐾</div>
        <h4>Socialisation</h4>
        <p>Interactions avec autres chiens</p>
      </div>
    </div>
  </div>
</section>

<section class="why-section" id="why">
  <div class="section-inner">
    <p class="section-label">Nos engagements</p>
    <h2 class="section-title">Pourquoi choisir <em>CanisPro ?</em></h2>
    <p class="section-sub">Une approche bienveillante, des éducateurs certifiés et un suivi personnalisé pour chaque chien.</p>
 
    <div class="why-grid">
      <div class="why-card">
        <div class="why-icon green"><img src="{{ asset('images/prof.png') }}" width="36" height="36"></div>
        <h3>Éducateurs certifiés</h3>
        <p>Tous nos éducateurs sont titulaires du ACACED et d'une certification en éducation canine positive.</p>
      </div>
      <div class="why-card">
        <div class="why-icon amber"><img src="{{ asset('images/approbation.png') }}" width="36" height="36"></div>
        <h3>Méthodes positives</h3>
        <p>Nous n'utilisons que des méthodes de renforcement positif, sans contrainte ni punition.</p>
      </div>
      <div class="why-card">
        <div class="why-icon blue"><img src="{{ asset('images/statistique.png') }}" width="36" height="36"></div>
        <h3>Suivi personnalisé</h3>
        <p>Suivez la progression de votre chien en temps réel avec les notes de l'éducateur après chaque séance.</p>
      </div>
      <div class="why-card">
        <div class="why-icon pink"><img src="{{ asset('images/chien.png') }}" width="36" height="36"></div>
        <h3>Petits groupes</h3>
        <p>Maximum 8 chiens par cours pour garantir une attention individuelle et une progression optimale.</p>
      </div>
      <div class="why-card">
        <div class="why-icon teal"><img src="{{ asset('images/calendrier.png') }}" width="36" height="36"></div>
        <h3>Réservation en ligne</h3>
        <p>Réservez et gérez vos séances 24h/24 depuis votre espace propriétaire.</p>
      </div>
      <div class="why-card">
        <div class="why-icon purple">💬</div>
        <h3>Échanges facilités</h3>
        <p>Communiquez directement avec votre éducateur via la messagerie intégrée à votre espace.</p>
      </div>
    </div>
  </div>
</section>
<!-- ──────────────────────────────────────
     PAGE 2 — LISTE DES COURS
─────────────────────────────────────── -->
<section id="cours">
  <div class="section-inner">
    <p class="section-label">Nos formations</p>
    <h2 class="section-title">Tous les <em>cours disponibles</em></h2>
    <p class="section-sub">Des séances adaptées à tous les niveaux, en groupe ou en individuel.</p>

    <div class="cours-grid">

      <!-- Cours 1 -->
      <div class="cours-card">
        <div class="cours-img green">
          🐕
          <span class="cours-badge new">Nouveau</span>
        </div>
        <div class="cours-body">
          <span class="cours-level">Débutant</span>
          <h3 class="cours-title">Obéissance de base</h3>
          <p class="cours-desc">Apprentissage des ordres fondamentaux : assis, couché, reste, rappel. Idéal pour les jeunes chiens.</p>
          <div class="cours-meta">
            <span>📅 Lun & Mer 10h</span>
            <span>👥 6 / 8 places</span>
            <span>⏱ 1h</span>
          </div>
          <div class="cours-footer">
            <div class="cours-price">45€ <small>/ séance</small></div>
            <button class="btn-reserver">Réserver</button>
          </div>
        </div>
      </div>

      <!-- Cours 2 -->
      <div class="cours-card">
        <div class="cours-img amber">
          🏆
          <span class="cours-badge full">Complet</span>
        </div>
        <div class="cours-body">
          <span class="cours-level">Intermédiaire</span>
          <h3 class="cours-title">Agility niveau 2</h3>
          <p class="cours-desc">Parcours d'obstacles, sauts, tunnels et slaloms. Renforce la complicité chien-maître.</p>
          <div class="cours-meta">
            <span>📅 Sam 9h–11h</span>
            <span>👥 8 / 8 places</span>
            <span>⏱ 2h</span>
          </div>
          <div class="cours-footer">
            <div class="cours-price">60€ <small>/ séance</small></div>
            <button class="btn-reserver full" disabled>Complet</button>
          </div>
        </div>
      </div>

      <!-- Cours 3 -->
      <div class="cours-card">
        <div class="cours-img blue">
          🤝
        </div>
        <div class="cours-body">
          <span class="cours-level">Tous niveaux</span>
          <h3 class="cours-title">Socialisation</h3>
          <p class="cours-desc">Interactions contrôlées entre chiens. Gestion des réactions et développement de la confiance.</p>
          <div class="cours-meta">
            <span>📅 Jeu 14h</span>
            <span>👥 4 / 10 places</span>
            <span>⏱ 1h30</span>
          </div>
          <div class="cours-footer">
            <div class="cours-price">38€ <small>/ séance</small></div>
            <button class="btn-reserver">Réserver</button>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ──────────────────────────────────────
     PAGE 3 — DASHBOARD ADMIN
─────────────────────────────────────── -->
<section class="dashboard-section" id="dashboard">
  <div class="section-inner">
    <p class="section-label">Espace admin</p>
    <h2 class="section-title">Tableau de <em>bord</em></h2>

    <div class="dashboard-grid">

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-user">
          <div class="avatar">ML</div>
          <div>
            <div class="sidebar-user-name">Marie Lambert</div>
            <div class="sidebar-user-role">Administratrice</div>
          </div>
        </div>
        <nav class="sidebar-nav">
          <div class="sidebar-section-label">Principal</div>
          <a class="sidebar-link active" href="#">
            <span class="icon">📊</span> Tableau de bord
          </a>
          <a class="sidebar-link" href="#">
            <span class="icon">📚</span> Cours
          </a>
          <a class="sidebar-link" href="#">
            <span class="icon">📅</span> Planning
          </a>
          <div class="sidebar-section-label">Gestion</div>
          <a class="sidebar-link" href="#">
            <span class="icon">🐕</span> Chiens
          </a>
          <a class="sidebar-link" href="#">
            <span class="icon">👤</span> Propriétaires
          </a>
          
          <div class="sidebar-section-label">Autre</div>
          <a class="sidebar-link" href="#">
            <span class="icon">⚙️</span> Paramètres
          </a>
        </nav>
      </aside>

      <!-- Main content -->
      <div class="dash-main">
        <div class="dash-header">
          <div>
            <h2>Bonjour, Marie 👋</h2>
            <p>Lundi 9 mars 2026 — 3 cours aujourd'hui</p>
          </div>
          <a href="#" class="btn-sm">+ Nouveau cours</a>
        </div>

        <!-- KPIs -->
        <div class="kpi-row">
          <div class="kpi-card">
            <div class="kpi-icon">🐕</div>
            <div class="kpi-label">Chiens inscrits</div>
            <div class="kpi-value">84</div>
            <div class="kpi-delta">↑ +6 ce mois</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-icon">📚</div>
            <div class="kpi-label">Cours actifs</div>
            <div class="kpi-value">12</div>
            <div class="kpi-delta">↑ +2 cette semaine</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-icon">📅</div>
            <div class="kpi-label">Réservations</div>
            <div class="kpi-value">37</div>
            <div class="kpi-delta">↑ +12%</div>
          </div>
          <div class="kpi-card">
            <div class="kpi-icon">💰</div>
            <div class="kpi-label">Revenus / mois</div>
            <div class="kpi-value">284 455 110€</div>
            <div class="kpi-delta down">↓ -3%</div>
          </div>
        </div>

        <!-- Table cours -->
        <div class="table-card">
          <div class="table-card-header">
            <h3>Cours du jour</h3>
            <div style="display:flex;gap:0.5rem">
              <a href="#" class="btn-sm ghost">Voir tout</a>
              <a href="#" class="btn-sm">+ Ajouter</a>
            </div>
          </div>
          <table>
            <thead>
              <tr>
                <th>Cours</th>
                <th>Horaire</th>
                <th>Places</th>
                <th>Statut</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="td-name">Obéissance débutant</td>
                <td>10h00 – 11h00</td>
                <td>6 / 8</td>
                <td><span class="tag tag-green">● En cours</span></td>
                <td><a href="#" class="btn-sm ghost">Voir</a></td>
              </tr>
              <tr>
                <td class="td-name">Agility niveau 2</td>
                <td>14h00 – 16h00</td>
                <td>8 / 8</td>
                <td><span class="tag tag-amber">● Complet</span></td>
                <td><a href="#" class="btn-sm ghost">Voir</a></td>
              </tr>
              <tr>
                <td class="td-name">Socialisation</td>
                <td>17h30 – 19h00</td>
                <td>4 / 10</td>
                <td><span class="tag tag-blue">● À venir</span></td>
                <td><a href="#" class="btn-sm ghost">Voir</a></td>
              </tr>
              <tr>
                <td class="td-name">Rappel avancé</td>
                <td>Annulé</td>
                <td>—</td>
                <td><span class="tag tag-red">● Annulé</span></td>
                <td><a href="#" class="btn-sm ghost">Voir</a></td>
              </tr>
            </tbody>
          </table>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- ──────────────────────────────────────
     PAGE 4 — PROFIL CHIEN
─────────────────────────────────────── -->
<section class="profil-section" id="profil">
  <div class="section-inner">
    <p class="section-label">Fiche chien</p>
    <h2 class="section-title">Profil de <em>Rocky</em></h2>

    <div class="profil-grid">

      <!-- Carte gauche -->
      <div class="profil-card">
        <div class="profil-card-top">
          <span class="profil-animal-icon">🐕 ( photo )</span>
          <div class="profil-card-name">Rocky</div>
          <div class="profil-card-breed">Berger Australien • 3 ans</div>
        </div>
        <div class="profil-card-body">
          <div class="profil-info-row">
            <span class="profil-info-label">Race</span>
