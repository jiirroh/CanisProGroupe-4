      <!-- Contenu droite -->
      <div class="profil-right">

        <!-- Progression -->
        <div class="profil-section-card">
          <div class="profil-section-title">📈 Progression</div>
          <div class="progress-wrap">
            <div class="progress-label"><span>Obéissance</span><span>80%</span></div>
            <div class="progress-bar"><div class="progress-fill" style="width:80%"></div></div>
            <div class="progress-label"><span>Socialisation</span><span>65%</span></div>
            <div class="progress-bar"><div class="progress-fill" style="width:65%"></div></div>
            <div class="progress-label"><span>Agility</span><span>40%</span></div>
            <div class="progress-bar"><div class="progress-fill" style="width:40%"></div></div>
          </div>
        </div>

        <!-- Historique cours -->
        <div class="profil-section-card">
          <div class="profil-section-title">📚 Cours suivis</div>
          <div class="cours-historique">
            <div class="cours-hist-item">
              <div>
                <div class="cours-hist-name">Obéissance de base</div>
