{
  "name": "Symfony Project",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "sensiolabs.symfony-vscode-extension",
        "bmewburn.vscode-inteliphense-client",
        "mehdichabane.symfony-snippets"
      ]
    }
  },
  "remoteUser": "vscode"
}