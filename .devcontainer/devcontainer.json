{
    "name": "CanisPro PHP 8.4 Env",
    "dockerComposeFile": [
        "../compose.yaml"
    ],
    "service": "web",
    "workspaceFolder": "/var/www/html",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "nonu.php-extension-pack",
                "qebis.symfony-vscode"
            ]
        }
    },
    // Commande exécutée UNE SEULE FOIS à la création du Codespace
    "postCreateCommand": "composer install && php bin/console doctrine:migrations:migrate --no-interaction",
    "remoteUser": "root"
}