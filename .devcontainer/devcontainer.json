{
    "name": "CanisPro PHP 8.4 Env",
    "image": "mcr.microsoft.com/devcontainers/php:8.4",
    "workspaceFolder": "/workspaces/CanisProGroupe-4",
    "postCreateCommand": "bash .devcontainer/setup.sh",
    "remoteUser": "root",
    "forwardPorts": [8000, 3306],
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "nonu.php-extension-pack",
                "qebis.symfony-vscode",
                "cweijan.vscode-mysql-client2"
            ]
        }
    }
}